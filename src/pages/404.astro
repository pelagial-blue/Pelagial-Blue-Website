---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Page not found — Robert Bewick" description="The page you requested could not be found.">
  <main class="section">
    <div class="container">
      <div class="glass" style="padding: 18px;">
        <h1 style="margin: 0 0 8px; font-size: 26px; letter-spacing: -0.02em;">Page not found</h1>
        <p style="margin: 0; color: rgba(255,255,255,0.72);">The page you’re looking for doesn’t exist.</p>
        <div style="margin-top: 16px;">
          <a class="btn primary" href="/">Go home</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
